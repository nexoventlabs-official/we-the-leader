# ── We The Leaders — Environment Variables Template ──────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

PORT=5000
NODE_ENV=development

# ── DB1: Voter Roll (DigitalOcean) — READ-ONLY ────────────────────
MONGO_VOTER_URL=mongodb+srv://<user>:<password>@<host>/voter_db?authSource=admin&tls=true
MONGO_VOTER_DB_NAME=voter_db

# ── DB2: App Data (Atlas) — READ/WRITE ───────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wetheleaders?retryWrites=true&w=majority
MONGO_DB=wetheleaders

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PHOTO_FOLDER=member_photos
CLOUDINARY_CARDS_FOLDER=generated_cards

# ── Admin Credentials ─────────────────────────────────────────────
# Use strong credentials — NEVER use defaults
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Session ───────────────────────────────────────────────────────
# Must be at least 32 chars — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── SMS (2factor.in) ──────────────────────────────────────────────
SMS_API_KEY=

# ── WhatsApp Cloud API ────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_CHANNEL_URL=

# ── WhatsApp Flows ────────────────────────────────────────────────
WHATSAPP_FLOW_REGISTRATION_ID=
WHATSAPP_FLOW_LOGIN_ID=
# RSA private key for decrypting WhatsApp Flow requests (optional)
# Paste the PEM key with newlines replaced by \n
WHATSAPP_FLOW_PRIVATE_KEY=

# ── Application ───────────────────────────────────────────────────
# Production: set to your actual domain e.g. https://we-the-leader.onrender.com
BASE_URL=http://localhost:5000

# Frontend URL (added to CORS allowed origins in production)
# e.g. https://we-the-leader.vercel.app
FRONTEND_URL=

# Comma-separated extra CORS origins (optional, e.g. Vercel preview URLs)
EXTRA_ORIGINS=
